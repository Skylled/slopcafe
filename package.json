{
  "name": "slopcafe",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.6"
  },
  "description": "A Cloudflare Worker that lets authenticated agents publish HTML at unguessable URLs.",
  "main": "src/index.ts",
  "scripts": {
    "build:wasm": "cd sanitizer && PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build --target web --release --no-typescript",
    "build:openapi": "node --experimental-strip-types --no-warnings --import=./test/register-ts-resolver.mjs scripts/build-openapi.mjs",
    "predeploy": "npm run build:wasm && npm run build:openapi",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:sanitizer && npm run test:advisories && npm run test:metadata && npm run test:pagination && npm run test:search && npm run test:edit && npm run test:integrity && npm run test:auth && npm run test:session && npm run test:access && npm run test:conditional && npm run test:vector && npm run test:contract && npm run test:openapi",
    "test:sanitizer": "cd sanitizer && PATH=\"$HOME/.cargo/bin:$PATH\" cargo test",
    "test:advisories": "node --experimental-strip-types --no-warnings test/advisories.test.mjs",
    "test:metadata": "node --experimental-strip-types --no-warnings test/metadata.test.mjs",
    "test:pagination": "node --experimental-strip-types --no-warnings --import=./test/register-ts-resolver.mjs test/pagination.test.mjs",
    "test:search": "node --experimental-strip-types --no-warnings test/search.test.mjs",
    "test:edit": "node --experimental-strip-types --no-warnings test/edit.test.mjs",
    "test:integrity": "node --experimental-strip-types --no-warnings test/integrity.test.mjs",
    "test:auth": "node --experimental-strip-types --no-warnings --import=./test/register-ts-resolver.mjs test/auth.test.mjs",
    "test:session": "node --experimental-strip-types --no-warnings --import=./test/register-ts-resolver.mjs test/session.test.mjs",
    "test:access": "node --experimental-strip-types --no-warnings --import=./test/register-ts-resolver.mjs test/access.test.mjs",
    "test:conditional": "node --experimental-strip-types --no-warnings test/conditional.test.mjs",
    "test:vector": "node --experimental-strip-types --no-warnings test/vector.test.mjs",
    "test:contract": "node --experimental-strip-types --no-warnings test/contract.test.mjs",
    "test:openapi": "node --experimental-strip-types --no-warnings --import=./test/register-ts-resolver.mjs test/openapi.test.mjs",
    "db:migrate:local": "wrangler d1 migrations apply agent-web-host-meta --local",
    "db:migrate:remote": "wrangler d1 migrations apply agent-web-host-meta --remote",
    "db:console:local": "wrangler d1 execute agent-web-host-meta --local --command",
    "db:console:remote": "wrangler d1 execute agent-web-host-meta --remote --command"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.95.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Skylled/slopcafe.git"
  },
  "keywords": [],
  "author": "Skylled / Kyle Bradshaw",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Skylled/slopcafe/issues"
  },
  "homepage": "https://github.com/Skylled/slopcafe#readme",
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.13.3",
    "zod": "^4.4.3"
  }
}
