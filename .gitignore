# Dependencies
node_modules/

# Wrangler local state (dev server, local D1/KV/R2, build artifacts)
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example

# Personal Worker config — copy wrangler.toml.example → wrangler.toml and fill in
# your own account/resource IDs. Untracked on purpose so instance identifiers
# (account_id, database_id, KV id, custom-domain routes) never reach version control.
wrangler.toml

# Build output
dist/
build/
*.tsbuildinfo

# Rust / wasm-pack outputs (sanitizer crate)
sanitizer/target/
sanitizer/pkg/

# Secrets / environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / test artifacts
coverage/
.nyc_output/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
